# ─────────────────────────────────────────────────────────────────
# HobeRadius — License Admin Panel
# نسخ هذا الملف إلى .env وعدّل القيم قبل التشغيل
# ─────────────────────────────────────────────────────────────────

# ── بيئة التشغيل ──────────────────────────────────────────────────
# dev | bootstrap | production
LICENSE_PANEL_ENV=production
FLASK_DEBUG=0

# ── المفتاح السري للجلسات ─────────────────────────────────────────
# أنشئه بـ: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET=replace-with-a-long-random-flask-secret

# ── قاعدة البيانات ────────────────────────────────────────────────
# SQLite (dev):      sqlite:////var/lib/hoberadius-admin/admin.db
# PostgreSQL (prod): postgresql+psycopg2://user:pass@localhost/hoberadius_admin
DATABASE_URL=sqlite:////var/lib/hoberadius-admin/admin.db

# ── حساب المدير الأول (يُنشأ تلقائيًا عند أول تشغيل) ────────────
LICENSE_ADMIN_USERNAME=admin
LICENSE_ADMIN_EMAIL=admin@your-panel.com
LICENSE_ADMIN_PASSWORD=replace-with-a-strong-unique-admin-password

# ── الـ Vault — مفتاح تشفير الأسرار ─────────────────────────────
# أنشئه بـ: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ملاحظة أمنية: المفاتيح الخاصة لا تُخزَّن هنا أبدًا — Vault Ref فقط
CUSTOMER_VAULT_ENCRYPTION_KEY=replace-with-fernet-key

# ── HMAC لتوقيع طلبات التحقق من الترخيص ─────────────────────────
# أنشئه بـ: python -c "import secrets; print(secrets.token_hex(32))"
# يجب أن يتطابق مع HOBERADIUS_ADMIN_SHARED_SECRET في كل نسخة عميل
LICENSE_CHECK_HMAC_SECRET=replace-with-strong-hmac-secret-min-32-chars

# ── وكيل RADIUS المركزي ──────────────────────────────────────────
# ملاحظة: منافذ RADIUS 1812/1813 لا تُفتح للإنترنت — WireGuard tunnel فقط
RADIUS_PROXY_SHARED_SECRET=replace-with-proxy-shared-secret

# ── الكوكيز ───────────────────────────────────────────────────────
SESSION_COOKIE_SAMESITE=Strict
# يجب تفعيله في الإنتاج مع HTTPS
# SESSION_COOKIE_SECURE=1

# ── الإعدادات الافتراضية ──────────────────────────────────────────
DEFAULT_CURRENCY=USD
SUPPORT_EMAIL=support@your-panel.com
SUPPORT_PHONE=+1-000-000-0000
DEFAULT_GRACE_DAYS=3

# ── الأمان المتقدم ────────────────────────────────────────────────
# RATE_LIMITS_ENABLED=1
# LOGIN_RATE_LIMIT_MAX=10
# LOGIN_RATE_LIMIT_WINDOW_SECONDS=900
# LICENSE_CHECK_RATE_LIMIT_MAX=120
# LICENSE_CHECK_RATE_LIMIT_WINDOW_SECONDS=60
# LICENSE_CHECK_ALLOW_UNSIGNED=0
# LICENSE_CHECK_SIGNATURE_REQUIRED=1
# TRUST_PROXY_HEADERS=1    # فعّل إن كانت وراء Nginx/Caddy

# ── RouterOS / CHR (عقد VPN) ─────────────────────────────────────
# CHR_USERNAME=admin
# CHR_PUBLIC_IP=
# CHR_PUBLIC_HOST=
# CHR_DEFAULT_PPP_PROFILE=default
# CHR_PPP_LOCAL_ADDRESS=10.0.0.1
# CHR_PPP_ADDRESS_POOL=vpn-pool
# CHR_PPP_POOL_RANGES=10.0.0.2-10.0.0.254
# CHR_IPSEC_ADDRESS_POOL=ipsec-pool
# CHR_IPSEC_PEER=ike2-peer
# CHR_IPSEC_PROFILE=ike2-profile
# CHR_IPSEC_MODE_CONFIG=ike2-config
# CHR_IPSEC_CERTIFICATE=ike2-cert
# CHR_IPSEC_EAP_METHODS=eap-mschapv2
# CHR_IPSEC_DNS=1.1.1.1,8.8.8.8

# ── مستوى الـ Log ─────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── WhatsApp (اختياري) ────────────────────────────────────────────
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_BUSINESS_ACCOUNT_ID=
# WHATSAPP_FERNET_KEY=
# META_APP_ID=
# META_APP_SECRET=
# META_CONFIG_ID=
# META_GRAPH_VERSION=v19.0
