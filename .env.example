FLASK_SECRET=change-this-secret
DATABASE_URL=sqlite:///license_panel.sqlite3
LICENSE_PANEL_ENV=local
LICENSE_ADMIN_USERNAME=admin
LICENSE_ADMIN_PASSWORD=change-this-password
LICENSE_ADMIN_EMAIL=admin@example.com
DEFAULT_GRACE_DAYS=7
DEFAULT_CURRENCY=USD
SUPPORT_EMAIL=support@example.com
SUPPORT_PHONE=
AUTO_INIT_DB=1
RATE_LIMITS_ENABLED=1
LOGIN_RATE_LIMIT_MAX=10
LOGIN_RATE_LIMIT_WINDOW_SECONDS=900
LICENSE_CHECK_RATE_LIMIT_MAX=120
LICENSE_CHECK_RATE_LIMIT_WINDOW_SECONDS=60
LICENSE_KEY_RATE_LIMIT_MAX=600
LICENSE_KEY_RATE_LIMIT_WINDOW_SECONDS=300
LICENSE_CHECK_HMAC_SECRET=
LICENSE_CHECK_SIGNATURE_REQUIRED=0
LICENSE_CHECK_ALLOW_UNSIGNED=1
LICENSE_CHECK_MAX_CLOCK_SKEW_SECONDS=300
LICENSE_CHECK_REPLAY_WINDOW_SECONDS=600
LICENSE_CHECK_NONCE_CACHE_MAX=5000
TRUST_PROXY_HEADERS=0
SESSION_COOKIE_SECURE=0
SESSION_COOKIE_SAMESITE=Lax
SESSION_LIFETIME_SECONDS=43200
LOG_LEVEL=INFO

# ─── Customer Secure Vault + CHR password encryption (REQUIRED for CHR) ───────
# Fernet key used to encrypt per-customer vault secrets AND the central CHR
# password AND provisioned tunnel passwords at rest. Generate ONCE and keep
# stable — rotating it makes stored secrets unrecoverable. Generate with:
#   python -c "from cryptography.fernet import Fernet;print(Fernet.generate_key().decode())"
CUSTOMER_VAULT_ENCRYPTION_KEY=

# ─── MikroTik CHR central tunnel provisioning (SSTP/PPTP/L2TP) ────────────────
# The CHR host/port/user/PASSWORD are entered by the OWNER in the panel Settings
# page (stored in the DB; the password encrypted with CUSTOMER_VAULT_ENCRYPTION_KEY)
# — NOT here. These env vars are only toggles/defaults.
CHR_PROVISIONING_ENABLED=1
# RouterOS REST runs over HTTPS via the www-ssl service (NOT the binary API on
# 8728/8729). Default REST port when the panel's port field is left blank. Use
# 8443 because 443 is taken by SSTP in this deployment.
CHR_REST_DEFAULT_PORT=8443
# RouterOS REST ships a self-signed cert by default so verification is off. The
# real CHR now has a valid Let's Encrypt cert on its domain — set to 1 to verify.
CHR_TLS_VERIFY=0
# Documentation only (the app does NOT read this to enforce anything): the IP
# allowed to control the CHR REST endpoint is restricted ON THE ROUTEROS SIDE via
# the www-ssl service address= allow-list (and/or firewall). The panel server IP
# (e.g. 178.105.180.6/32) must be the only one allowed there.
CHR_API_ALLOWED_IP=
CHR_HTTP_TIMEOUT_SECONDS=15
# Fallback ceiling for simultaneous tunnels per customer when their VPN
# entitlement does not set max_vpn_users.
CHR_DEFAULT_MAX_TUNNELS=5
# Default /ppp/profile applied to provisioned secrets on the CHR.
CHR_DEFAULT_PPP_PROFILE=default
# CHR management console (admin page, super-admin only). Turn off to hide it
# without affecting tunnel provisioning. No credentials — operational toggle.
CHR_CONSOLE_ENABLED=1

# ─── IPsec / IKEv2 automation on the CHR (/ip/ipsec, NOT /ppp/secret) ─────────
# IPsec tunnels are auto-created on the CHR: per user an /ip/ipsec/user entry
# (IKEv2 EAP-MSCHAPv2), plus a shared responder (mode-config/peer/identity)
# ensured once. Set to 0 to fall back to record-only IPsec (manual CHR setup).
CHR_IPSEC_AUTO_PROVISION=1
# Set to 0 if you configured the IKEv2 responder manually and want the panel to
# only manage the per-user /ip/ipsec/user entries.
CHR_IPSEC_MANAGE_INFRA=1
# Stable names of the shared responder objects created/reused on the CHR.
CHR_IPSEC_PEER=hoberadius
CHR_IPSEC_MODE_CONFIG=hoberadius
CHR_IPSEC_PROFILE=default
CHR_IPSEC_EAP_METHODS=eap-mschapv2
# One-time responder prerequisites the OWNER provisions on the CHR (leave empty
# to skip): client address pool, DNS to push, and the server certificate the
# IKEv2 responder presents for EAP. Without a certificate, EAP clients can't
# complete the handshake — set CHR_IPSEC_CERTIFICATE to an installed cert name.
CHR_IPSEC_ADDRESS_POOL=
CHR_IPSEC_DNS=
CHR_IPSEC_CERTIFICATE=

# ─── Public CHR endpoint advertised to customer clients (over the bridge) ─────
# The address/ports the END customer's device connects to (may differ from the
# REST management host if the CHR is behind NAT). These are entered by the OWNER
# in the panel Settings page (public host + per-service ports) and travel in the
# bridge tunnel-delivery contract; nothing secret here.

# ─── WhatsApp encryption (REQUIRED if WhatsApp is used) ───────────────────────
# Fernet key used to encrypt every WhatsApp access token / webhook secret at
# rest. Generate ONCE and keep stable — rotating it makes stored tokens
# unrecoverable. Generate with:  python -c "from cryptography.fernet import Fernet;print(Fernet.generate_key().decode())"
WHATSAPP_FERNET_KEY=

# ─── Meta WhatsApp Embedded Signup (customer self-service onboarding) ─────────
# Feature flag: when off, the embedded CTA is hidden and the manual/advanced
# path remains. When on but creds are missing, the customer sees a friendly
# "admin setup incomplete" notice (never a broken button).
WHATSAPP_EMBEDDED_SIGNUP_ENABLED=1
# Meta App credentials (from developers.facebook.com → your app).
META_APP_ID=
# Server-side ONLY — never sent to the browser. Keep secret.
META_APP_SECRET=
# Embedded Signup configuration id (Meta: WhatsApp → Embedded Signup config).
# NOTE: the env var the app reads is META_CONFIG_ID (a.k.a. the
# "Embedded Signup Config ID" / META_EMBEDDED_SIGNUP_CONFIG_ID in product docs).
META_CONFIG_ID=
# Graph API version (defaults to WHATSAPP_GRAPH_API_VERSION, else v21.0).
META_GRAPH_VERSION=v21.0
# Optional explicit OAuth redirect override (else derived from the request).
META_OAUTH_REDIRECT_URI=
# Lifetime (seconds) of a server-issued embedded-signup state/nonce session.
META_EMBEDDED_ATTEMPT_TTL_SECONDS=600
# When 1, the completion callback MUST carry a valid server-issued state (no
# legacy/no-state path). Default 0 — the callback still enforces state whenever
# the frontend supplies it (the shipped frontend always does).
META_EMBEDDED_REQUIRE_STATE=0

# ─── WhatsApp Cloud API house/manual settings (admin/fallback path) ───────────
# House credentials can also be managed encrypted from the admin Settings page
# (these env values are a fallback when no DB value is saved).
WHATSAPP_CLOUD_SETTINGS_ENABLED=1
WHATSAPP_GRAPH_API_VERSION=v21.0
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
