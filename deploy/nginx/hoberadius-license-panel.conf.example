server {
    listen 80;
    server_name license.example.com;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name license.example.com;

    ssl_certificate /etc/letsencrypt/live/license.example.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/license.example.com/privkey.pem;

    # Body-size limits — IMPORTANT (fixes HTTP 413 on backup upload).
    # The customer backup upload sends the full SQLite file base64-encoded in a
    # JSON body; base64 inflates it ~33%, so a 188 MB backup arrives as ~250 MB
    # and keeps growing. We therefore allow a LARGE body on BOTH the server
    # block AND the specific upload location so the request can never fall back
    # to a small distro default (1m) or the old tight value and 413 before the
    # app sees it. The app still enforces its own per-upload cap
    # (BACKUP_MAX_STORED_BYTES, default 1 GB) and returns a clean message.
    #
    # NOTE: this is the GATEWAY config. nginx is host-managed (outside the app
    # deploy), so this value MUST be applied to the LIVE config on the licensing
    # VPS — copying this .example into place (or merging these two directives)
    # and running `nginx -t && systemctl reload nginx`. If a separate front
    # proxy / server block sits in front, raise client_max_body_size there too.
    client_max_body_size 1g;

    # Backup upload carries the full SQLite file (base64) — allow a generous body
    # ONLY on this endpoint, comfortably above the app's 1 GB decoded cap
    # (base64 of 1 GB ≈ 1.34 GB), so the app's "too_large" wins over an nginx 413.
    location = /api/integration/hoberadius/backups/upload {
        client_max_body_size 2g;
        proxy_pass http://127.0.0.1:5055;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Connection "";
        proxy_read_timeout 300s;
        proxy_send_timeout 300s;
    }

    location / {
        proxy_pass http://127.0.0.1:5055;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Connection "";
        proxy_read_timeout 60s;
        proxy_send_timeout 60s;
    }
}
