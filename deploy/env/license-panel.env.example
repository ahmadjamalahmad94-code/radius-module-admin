# Copy to /etc/hoberadius-license-panel/license-panel.env and replace all placeholders.
# Do not commit real secrets.

LICENSE_PANEL_ENV=production
FLASK_DEBUG=0
FLASK_SECRET=replace-with-a-long-random-flask-secret
DATABASE_URL=postgresql+psycopg://license_user:replace-password@127.0.0.1:5432/license_panel

LICENSE_ADMIN_USERNAME=admin
LICENSE_ADMIN_PASSWORD=replace-with-a-strong-unique-admin-password
LICENSE_ADMIN_EMAIL=admin@example.com

DEFAULT_GRACE_DAYS=7
DEFAULT_CURRENCY=USD
SUPPORT_EMAIL=support@example.com
SUPPORT_PHONE=+0000000000
AUTO_INIT_DB=0

RATE_LIMITS_ENABLED=1
LOGIN_RATE_LIMIT_MAX=10
LOGIN_RATE_LIMIT_WINDOW_SECONDS=900
LICENSE_CHECK_RATE_LIMIT_MAX=120
LICENSE_CHECK_RATE_LIMIT_WINDOW_SECONDS=60
LICENSE_KEY_RATE_LIMIT_MAX=600
LICENSE_KEY_RATE_LIMIT_WINDOW_SECONDS=300

# Legacy link-signing env knobs (HMAC secret / signature-required /
# allow-unsigned / clock-skew / replay-window / nonce-cache) were retired
# with the bearer-only link contract — docs/SIMPLE_LINK_CONTRACT.md. The
# license key carried in the request body authenticates the bridge over HTTPS.

TRUST_PROXY_HEADERS=1
SESSION_COOKIE_SECURE=1
SESSION_COOKIE_SAMESITE=Lax
SESSION_LIFETIME_SECONDS=43200
LOG_LEVEL=INFO

# Customer backup upload sizing (fixes HTTP 413 on large backups). The instance
# uploads its full SQLite file base64-encoded (~+33%), so a 188 MB backup is a
# ~250 MB request body and grows over time. MAX_REQUEST_BODY_MB caps the Flask
# request body; BACKUP_MAX_STORED_MB caps the decoded file the panel stores.
# Keep both well above the largest backup. nginx must ALSO allow the body — see
# deploy/nginx/hoberadius-license-panel.conf.example (host-managed).
MAX_REQUEST_BODY_MB=2048
BACKUP_MAX_STORED_MB=1024

# WhatsApp gateway (Meta Cloud API). The drain timer sends queued messages.
# WHATSAPP_FERNET_KEY MUST be a generated Fernet key (urlsafe base64, 32 bytes):
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
WHATSAPP_FERNET_KEY=replace-with-a-generated-fernet-key

# Customer Secure Vault — encrypts per-customer secrets at rest (Fernet).
# Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# WARNING: if you LOSE this key, existing vault secrets cannot be decrypted.
# Keep it out of the database and out of version control.
CUSTOMER_VAULT_ENCRYPTION_KEY=replace-with-a-generated-fernet-key

WHATSAPP_GRAPH_API_VERSION=v21.0
WHATSAPP_GRAPH_BASE=https://graph.facebook.com
WHATSAPP_HTTP_TIMEOUT_SECONDS=15
WHATSAPP_DRAIN_BATCH_SIZE=50
WHATSAPP_MAX_ATTEMPTS=3

# Meta WhatsApp Embedded Signup (self-service onboarding).
# Register a Meta App as a WhatsApp Tech Provider with an Embedded Signup
# configuration, then fill these. While META_APP_ID / META_CONFIG_ID are empty
# (or the flag is 0) the embedded-signup button is hidden and the manual
# "advanced" path is used instead — nothing breaks before creds exist.
META_EMBEDDED_SIGNUP_ENABLED=1
META_APP_ID=
META_APP_SECRET=
META_CONFIG_ID=
META_GRAPH_VERSION=v21.0
# Optional: override the OAuth redirect (else derived from the request host).
META_OAUTH_REDIRECT_URI=

# WhatsApp Cloud API settings panel (admin-managed house credentials).
# When enabled, an admin can store these in the panel settings (encrypted)
# instead of editing env. The env values below are a FALLBACK used only when no
# DB value is saved (saved DB settings override env). Leave empty to manage from
# the UI. Secrets here are optional fallbacks — prefer the encrypted DB store.
WHATSAPP_CLOUD_SETTINGS_ENABLED=1
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
